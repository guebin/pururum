# Editor bundle build (bundle output is committed; deps are not)
editor-src/node_modules/
electron-shell/node_modules/

# Internal working notes (devlog, requirements, session logs) — local only,
# never published: GitHub is the distribution channel
docs/

# Generated export page (written at runtime)
quarto_viewer/static/_export.html

# Electron packaged output (rebuild: cd electron-shell && npx electron-builder --mac dmg)
electron-shell/release/

# Full working-copy snapshots left by Codex sessions — never commit
pururum-cm-shared/
pururum-stabilize/

# Python leftovers / local misc
__pycache__/
*.pyc
.venv
build/
dist/
err/
.DS_Store
